{
  "name": "@lvce-editor/status-bar-worker-monorepo",
  "version": "0.0.0-dev",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "node packages/build/src/build.js",
    "build:static": "node packages/build/src/build-static.ts",
    "build:watch": "esbuild --format=esm --bundle --external:node:buffer --external:electron --external:ws --external:node:worker_threads --watch packages/status-bar-worker/src/statusBarWorkerMain.ts --outfile=.tmp/dist/dist/statusBarWorkerMain.js",
    "dev": "node packages/build/src/dev.js",
    "e2e": "npm run e2e --workspace=e2e",
    "format": "prettier --write .",
    "lint": "eslint . && prettier --check .",
    "measure": "npm run measure --workspace=@lvce-editor/status-bar-worker-memory",
    "test": "npm run test --workspaces --if-present",
    "type-check": "tsc -b"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 150
  },
  "devDependencies": {
    "@lvce-editor/eslint-config": "^17.1.0",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3"
  }
}
